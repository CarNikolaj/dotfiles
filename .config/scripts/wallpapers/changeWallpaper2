#!/bin/bash

DIR=$HOME/Pictures/wallpapers/
PICS=($(ls ${DIR}))

RANDOMPICS=${PICS[ $RANDOM % ${#PICS[@]} ]}

if [[ $(pidof swaybg) ]]; then
  pkill swaybg
fi

awww query || awww-daemon


#change-wallpaper using swww and color-sheme
awww img ${DIR}/${RANDOMPICS} --transition-fps 60 --transition-type fade --transition-duration 1
wal -i  ${DIR}/${RANDOMPICS}  
~/.config/hypr/pywal-colors.sh






. "${HOME}/.cache/wal/colors.sh"

# Generate Fuzzel config with pywal colors (hex + alpha suffix)
cat <<EOF > ~/.config/fuzzel/fuzzel.ini
[main]
font=monospace:size=16
width=45
lines=12
prompt=" > "
layer=overlay

[colors]
background=${background#\#}ee
text=${foreground#\#}ff
match=${color4#\#}ff
selection=${color1#\#}cc
selection-text=${foreground#\#}ff
selection-match=${color4#\#}ff
border=${color5#\#}ff

[border]
width=2
radius=8
EOF

# Generate wlogout icons with pywal foreground color
ICON_DIR="$HOME/.config/wlogout/icons"
FG="${foreground}"

cat > "$ICON_DIR/lock.svg" <<IEOF
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 24 24" fill="none" stroke="${FG}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="3"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16.5" r="1.5"/></svg>
IEOF

cat > "$ICON_DIR/suspend.svg" <<IEOF
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 24 24" fill="none" stroke="${FG}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/></svg>
IEOF

cat > "$ICON_DIR/hibernate.svg" <<IEOF
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 24 24" fill="none" stroke="${FG}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/><path d="M7.5 3.5L6 2"/><path d="M16.5 3.5L18 2"/></svg>
IEOF

cat > "$ICON_DIR/reboot.svg" <<IEOF
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 24 24" fill="none" stroke="${FG}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
IEOF

cat > "$ICON_DIR/shutdown.svg" <<IEOF
<svg xmlns="http://www.w3.org/2000/svg" width="256" height="256" viewBox="0 0 24 24" fill="none" stroke="${FG}" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>
IEOF

# Generate wlogout style with pywal colors
hex2rgba() { printf "rgba(%d, %d, %d, %s)" "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}" "$2"; }
BG=$(hex2rgba "$background" "0.65")
BG_BTN=$(hex2rgba "$background" "0.25")
FG_BORDER=$(hex2rgba "$foreground" "0.12")
FG_BORDER_TOP=$(hex2rgba "$foreground" "0.20")
ACCENT_BG=$(hex2rgba "$color4" "0.30")
ACCENT_BORDER=$(hex2rgba "$color4" "0.45")
ACCENT2_BORDER=$(hex2rgba "$color5" "0.50")
ACCENT_GLOW=$(hex2rgba "$color4" "0.15")

cat <<WEOF > ~/.config/wlogout/style.css
/* Auto-generated by pywal */

* {
    background-image: none;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 14px;
}

window {
    background-color: ${BG};
}

button {
    background-color: ${BG_BTN};
    border: 1px solid ${FG_BORDER};
    border-top-color: ${FG_BORDER_TOP};
    border-radius: 20px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.10),
                inset 0 -1px 0 rgba(0, 0, 0, 0.06);
    color: ${foreground};
    margin: 10px;
    background-repeat: no-repeat;
    background-position: center 32%;
    background-size: 22%;
    text-decoration-color: ${foreground};
}

button:focus, button:active, button:hover {
    background-color: ${ACCENT_BG};
    border-color: ${ACCENT_BORDER};
    border-top-color: ${ACCENT2_BORDER};
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18),
                inset 0 -1px 0 rgba(0, 0, 0, 0.08),
                0 0 20px ${ACCENT_GLOW};
    color: ${color5};
    outline-style: none;
}

#lock {
    background-image: url("/home/niko/.config/wlogout/icons/lock.svg");
}
#suspend {
    background-image: url("/home/niko/.config/wlogout/icons/suspend.svg");
}
#hibernate {
    background-image: url("/home/niko/.config/wlogout/icons/hibernate.svg");
}
#shutdown {
    background-image: url("/home/niko/.config/wlogout/icons/shutdown.svg");
}
#reboot {
    background-image: url("/home/niko/.config/wlogout/icons/reboot.svg");
}
WEOF

# Generate CyberDolphin Kvantum + KDE color scheme from pywal
hex2rgb() { printf "%d,%d,%d" "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}"; }
BG_RGB=$(hex2rgb "$background")
FG_RGB=$(hex2rgb "$foreground")
C1_RGB=$(hex2rgb "$color1")
C2_RGB=$(hex2rgb "$color2")
C3_RGB=$(hex2rgb "$color3")
C4_RGB=$(hex2rgb "$color4")
C5_RGB=$(hex2rgb "$color5")
C6_RGB=$(hex2rgb "$color6")
C8_RGB=$(hex2rgb "$color8")

# Slightly lighter bg for alternates
ALT_R=$(( $(printf '%d' "0x${background:1:2}") + 8 ))
ALT_G=$(( $(printf '%d' "0x${background:3:2}") + 6 ))
ALT_B=$(( $(printf '%d' "0x${background:5:2}") + 10 ))
ALT_RGB="${ALT_R},${ALT_G},${ALT_B}"

BTN_R=$(( $(printf '%d' "0x${background:1:2}") + 13 ))
BTN_G=$(( $(printf '%d' "0x${background:3:2}") + 11 ))
BTN_B=$(( $(printf '%d' "0x${background:5:2}") + 18 ))
BTN_RGB="${BTN_R},${BTN_G},${BTN_B}"

# Darker bg
DK_R=$(( $(printf '%d' "0x${background:1:2}") > 8 ? $(printf '%d' "0x${background:1:2}") - 8 : 0 ))
DK_G=$(( $(printf '%d' "0x${background:3:2}") > 8 ? $(printf '%d' "0x${background:3:2}") - 8 : 0 ))
DK_B=$(( $(printf '%d' "0x${background:5:2}") > 8 ? $(printf '%d' "0x${background:5:2}") - 8 : 0 ))
DK_RGB="${DK_R},${DK_G},${DK_B}"

sed -i \
  -e "s/window\.color=.*/window.color=${background}/" \
  -e "s/base\.color=.*/base.color=#$(printf '%02x%02x%02x' $DK_R $DK_G $DK_B)/" \
  -e "s/alt\.base\.color=.*/alt.base.color=#$(printf '%02x%02x%02x' $ALT_R $ALT_G $ALT_B)/" \
  -e "s/button\.color=.*/button.color=#$(printf '%02x%02x%02x' $BTN_R $BTN_G $BTN_B)/" \
  -e "s/highlight\.color=.*/highlight.color=${color4}/" \
  -e "s/inactive\.highlight\.color=.*/inactive.highlight.color=${color1}/" \
  -e "s/text\.color=.*/text.color=${foreground}/" \
  -e "s/window\.text\.color=.*/window.text.color=${foreground}/" \
  -e "s/light\.color=.*/light.color=${color1}/" \
  -e "s/dark\.color=.*/dark.color=#$(printf '%02x%02x%02x' $DK_R $DK_G $DK_B)/" \
  ~/.config/Kvantum/CyberDolphin/CyberDolphin.kvconfig

# Update KDE color scheme
cat > ~/.local/share/color-schemes/CyberDolphin.colors <<CEOF
[ColorEffects:Disabled]
Color=56,56,56
ColorAmount=0
ColorEffect=0
ContrastAmount=0.65
ContrastEffect=1
IntensityAmount=0.1
IntensityEffect=2

[ColorEffects:Inactive]
ChangeSelectionColor=true
Color=${BG_RGB}
ColorAmount=0.025
ColorEffect=2
ContrastAmount=0.1
ContrastEffect=2
Enable=false
IntensityAmount=0
IntensityEffect=0

[Colors:Button]
BackgroundAlternate=${BTN_RGB}
BackgroundNormal=${BTN_RGB}
DecorationFocus=${C4_RGB}
DecorationHover=${C5_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:Complementary]
BackgroundAlternate=${DK_RGB}
BackgroundNormal=${BG_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:Header]
BackgroundAlternate=${DK_RGB}
BackgroundNormal=${BG_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:Selection]
BackgroundAlternate=${C1_RGB}
BackgroundNormal=${C4_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${FG_RGB}
ForegroundLink=${C5_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${BG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:Tooltip]
BackgroundAlternate=${DK_RGB}
BackgroundNormal=${BG_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:View]
BackgroundAlternate=${ALT_RGB}
BackgroundNormal=${DK_RGB}
DecorationFocus=${C4_RGB}
DecorationHover=${C5_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[Colors:Window]
BackgroundAlternate=${ALT_RGB}
BackgroundNormal=${BG_RGB}
DecorationFocus=${C4_RGB}
DecorationHover=${C5_RGB}
ForegroundActive=${C5_RGB}
ForegroundInactive=${C8_RGB}
ForegroundLink=${C4_RGB}
ForegroundNegative=${C3_RGB}
ForegroundNeutral=${C6_RGB}
ForegroundNormal=${FG_RGB}
ForegroundPositive=${C2_RGB}
ForegroundVisited=${C6_RGB}

[General]
ColorScheme=CyberDolphin
Name=CyberDolphin
shadeSortColumn=true

[KDE]
contrast=4

[WM]
activeBackground=${BG_RGB}
activeBlend=${FG_RGB}
activeForeground=${FG_RGB}
inactiveBackground=${DK_RGB}
inactiveBlend=${C8_RGB}
inactiveForeground=${C8_RGB}
CEOF



hyprctl reload

